# Telegram
TG_API_ID=39533004
TG_API_HASH=

# Token enrichment
DEFI_API_KEY=
ETHERSCAN_API_KEY=
COINGECKO_API_KEY=
SURF_API_KEY=
RUGCHECK_SHIELD_KEY=
ZERION_API_KEY=
ALCHEMY_API_KEY=
HELIUS_API_KEY=
TELEGRAM_BOT_TOKEN=

# Remote Worker - offloads ALL API calls to a free VPS
# Set this to your deployed worker URL (Render, Oracle Cloud, Fly.io, Railway)
# Example: https://hermes-worker.onrender.com
HERMES_WORKER_URL=

# TOR SOCKS5 proxy - routes ALL external HTTP through TOR
HERMES_TOR_ENABLED=true
TOR_SOCKS5=socks5h://127.0.0.1:9050
