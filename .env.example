# ═══════════════════════════════════════════════════════════════
# Hermes Token Screener - Environment Configuration
# Copy this file to .env and fill in your API keys
# ═══════════════════════════════════════════════════════════════

# Telegram (for contract scraper)
TG_API_ID=your_telegram_api_id
TG_API_HASH=your_telegram_api_hash

# Dexscreener (free, no key needed)

# GoPlus Security (free for v2, no key needed)

# De.Fi GraphQL
DEFI_API_KEY=your_defi_api_key

# CoinGecko
COINGECKO_API_KEY=your_coingecko_api_key

# Etherscan / BaseScan
ETHERSCAN_API_KEY=your_etherscan_api_key

# RugCheck (Solana security)
RUGCHECK_API_KEY=your_rugcheck_api_key
RUGCHECK_SHIELD_KEY=your_rugcheck_shield_key

# GMGN (data only, never trading)
GMGN_API_KEY=your_gmgn_api_key

# Surf (market context + social)
SURF_API_KEY=your_surf_api_key

# Alchemy (EVM webhooks for wallet tracking)
ALCHEMY_API_KEY=your_alchemy_api_key

# QuickNode (EVM webhooks)
QUICKNODE_KEY=your_quicknode_key

# Helius (Solana webhooks for wallet tracking)
HELIUS_API_KEY=your_helius_api_key
