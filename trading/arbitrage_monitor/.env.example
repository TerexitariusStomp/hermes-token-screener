
# Arbitrage Monitor Environment Variables
# Copy to ~/.hermes/arbitrage.env and adjust values

# Chain names as comma-separated list
ARBITRAGE_CHAINS="base,ethereum,arbitrum"

# Token pairs to monitor — IN/OUT direction matters!
# Use contract addresses, not symbols.
# Example: WETH→USDC & USDC→WETH on Base:
# ARBITRAGE_PAIRS="0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2/0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48,0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48/0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2"
ARBITRAGE_PAIRS=""

# Minimum net profit (after all fees + gas) to trigger alert
ARBITRAGE_MIN_PROFIT_ETH=0.015

# How often (seconds) to scan all pairs across all chains
ARBITRAGE_POLL_INTERVAL=30

# Amount (in ETH) to quote each direction
ARBITRAGE_QUOTE_AMOUNT_ETH=1.0

# Telegram notifications (optional)
ARBITRAGE_TELEGRAM_BOT_TOKEN=""
ARBITRAGE_TELEGRAM_CHAT_ID=""

# Override default RPCs (leave blank to use built-in defaults)
# ARBITRAGE_RPC_ETHEREUM="https://eth.llamarpc.com"
# ARBITRAGE_RPC_BASE="https://base.llamarpc.com"
