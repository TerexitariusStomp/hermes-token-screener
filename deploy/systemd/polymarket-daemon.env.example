# /etc/default/hermes-polymarket-daemon
# Runtime config for scripts/run_polymarket_daemon.sh

PYTHON_BIN=python3
QUERY=bitcoin
MODE=paper
INTERVAL_SECONDS=60
MIN_EDGE=0.01
STAKE_USDC=20

MARKET_SOURCE=gamma
QUOTE_SOURCE=clob
EXECUTOR=clob-v1

POLY_DATA_DIR=/root/workspace/polymarket-bot/poly_data
POLY_VOLUME_WEIGHT=0
USE_SUBGRAPH_SIGNAL=0
SUBGRAPH_ENDPOINT=https://api.goldsky.com/api/public/project_cl6mb8i9h0003e201j6li0diw/subgraphs/orderbook-subgraph/0.0.1/gn

MAX_ITERATIONS=0
MAX_RUNTIME_MINUTES=0
MAX_DAILY_LOSS_USD=0
COOLDOWN_ON_ERROR_SECONDS=30

LOG_FILE=logs/polymarket_trades.csv
